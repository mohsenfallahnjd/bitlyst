generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Comment {
  id        String   @id @default(cuid())
  slug      String
  name      String
  email     String?
  body      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([slug])
  @@index([approved])
}
